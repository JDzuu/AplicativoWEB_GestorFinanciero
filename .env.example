# Copia este archivo como ".env" y rellena los valores
# BACKEND

# "desarrollo" muestra /docs y desactiva HSTS. "produccion" lo oculta y activa HTTPS forzado.
ENTORNO=desarrollo

# En servidor poner la URL de tu PostgreSQL 
# DATABASE_URL=postgresql://usuario:clave@servidor:5432/nombre_de_tu_base
# Si dejas vacio el DATABASE_URL Automaticamente agarrara SQLite local  


# Dominios que tienen permiso de hablar con este backend.
ORIGENES_PERMITIDOS=http://localhost:5173,http://127.0.0.1:5173

# En servidor ejemplo: ORIGENES_PERMITIDOS=https://miempresa.com
# En un servidor: poner el dominio del backend para rechazar peticiones directas por IP.
# HOSTS_PERMITIDOS=miempresa.com

# Usuario administrador inicial (solo se usa si la base de datos está vacía).
# Si dejas ADMIN_PASSWORD vacío, se genera una contraseña aleatoria en la consola.
ADMIN_USUARIO=admin
ADMIN_NOMBRE=Administrador
ADMIN_PASSWORD=

# FRONTEND
VITE_API_URL=http://localhost:8000

# En un servidor: cambiar al dominio real del backend.
# Ejemplo: VITE_API_URL=https://miempresa.com